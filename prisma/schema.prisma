
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Player {
  id           Int      @id @default(autoincrement())
  name         String
  team         String
  position     String
  jerseyNumber Int
  country      String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}